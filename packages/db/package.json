{
  "name": "@traderiq/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "prisma generate && (test -z \"$DATABASE_URL_UNPOOLED\" || prisma migrate deploy)",
    "lint": "echo 'no lint'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist node_modules/.cache node_modules/.prisma",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:format": "prisma format"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
