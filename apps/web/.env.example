# Phase 1 — only NEXTAUTH_SECRET is technically required for production builds.
# Generate one with: openssl rand -base64 32

NEXTAUTH_SECRET=phase-1-demo-secret-please-rotate-in-prod
NEXTAUTH_URL=http://localhost:3000

# Phase 2 — uncomment when ready:
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# NOTIFY_EMAIL_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
# NOTIFY_PUSH_WEBHOOK_URL=https://expo-push-relay.example.com/send
# ABLEFY_WEBHOOK_SECRET=...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_VERIFY_SID=...
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
